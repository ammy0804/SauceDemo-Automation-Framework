<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="SauceDemo Cross-Browser Grid Suite" parallel="tests" thread-count="3" verbose="2">
    
    <listeners>
    <listener class-name="Listeners.TestListener"/> 
</listeners>

    <parameter name="environment" value="grid"/>
    
    <test name="Chrome Execution">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="tests.SauceTests"/>
        </classes>
    </test>

    <test name="Firefox Execution">
        <parameter name="browser" value="firefox"/>
        <classes>
            <class name="tests.SauceTests"/>
        </classes>
    </test>

    <test name="Edge Execution">
        <parameter name="browser" value="edge"/>
        <classes>
            <class name="tests.SauceTests"/>
        </classes>
    </test>

</suite>